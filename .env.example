# Discord webhook URL (required for alerts)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN

# Thresholds
DISK_ALERT_PCT=80
INODE_ALERT_PCT=80
MEMORY_ALERT_PCT=90
LOAD_ALERT_MULTIPLIER=2.0
SSL_WARN_DAYS=30

# Space-separated list of systemd system services to monitor
SERVICES=nginx ssh tailscaled

# Space-separated list of systemd --user services to monitor
USER_SERVICES=syncthing gpg-agent

# Space-separated list of domains to check SSL certs
SSL_DOMAINS=example.com api.example.com

# Comma-separated paths to backup files/dirs; alert if older than BACKUP_MAX_AGE_HOURS
BACKUP_PATHS=/var/backups/latest.tar.gz
BACKUP_MAX_AGE_HOURS=26
